{
  "name": "claude-context",
  "version": "0.1.0",
  "description": "A tool to manage and inject context into Claude AI conversations using vector search",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "claude-context": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "claude",
    "anthropic",
    "context",
    "vector-search",
    "milvus",
    "zilliz",
    "rag",
    "embeddings"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.0",
    "@zilliz/milvus2-sdk-node": "^2.4.0",
    "commander": "^12.0.0",
    "dotenv": "^16.4.0",
    "openai": "^4.47.0",
    "ora": "^5.4.1",
    "chalk": "^4.1.2",
    "inquirer": "^8.2.6",
    "glob": "^10.4.0",
    "tiktoken": "^1.0.15"
  },
  "devDependencies": {
    "@types/inquirer": "^8.2.10",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.ts",
      "**/*.test.ts"
    ],
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/**/*.d.ts"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 70
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/claude-context.git"
  },
  "bugs": {
    "url": "https://github.com/your-org/claude-context/issues"
  }
}
